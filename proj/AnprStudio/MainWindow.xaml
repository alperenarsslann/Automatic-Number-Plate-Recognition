<Window x:Class="AnprStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ANPR Studio" Height="900" Width="1420" MinHeight="680" MinWidth="1060"
        Closing="Window_Closing">
    <DockPanel>

        <!-- Top toolbar: paths + process control -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="anpr.exe:"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ExePathBox"/>
                <Button Grid.Row="0" Grid.Column="2" Content="..." Width="28" Margin="4,2,0,2" Click="BrowseExe_Click"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Config:"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ConfigPathBox"/>
                <Button Grid.Row="1" Grid.Column="2" Content="..." Width="28" Margin="4,2,0,2" Click="BrowseConfig_Click"/>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button x:Name="ReloadButton" Content="Reload Config" Width="100" Margin="0,0,6,0" Click="ReloadConfig_Click"/>
                    <Button x:Name="SaveButton" Content="Save Config" Width="100" Margin="0,0,6,0" Click="SaveConfig_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" Orientation="Horizontal">
                    <Button x:Name="StartButton" Content="▶ Start" Width="90" FontWeight="Bold" Margin="0,0,6,0" Click="Start_Click"/>
                    <Button x:Name="StopButton" Content="■ Stop" Width="90" IsEnabled="False" Click="Stop_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Stopped"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatsText" Text=""/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="370"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: config editor -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ConfigPanel" IsEnabled="False">

                    <GroupBox Header="Cameras (max 64)">
                        <StackPanel>
                            <ListBox x:Name="CamerasList" Height="120"
                                     SelectionChanged="CamerasList_SelectionChanged"/>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,4">
                                <Button Content="+ Add" Width="52" Margin="0,0,6,0" Click="AddCamera_Click"/>
                                <Button Content="- Remove" Width="66" Margin="0,0,6,0" Click="RemoveCamera_Click"/>
                                <Button x:Name="DiscoverButton" Content="🔍 Discover" Width="86" Margin="0,0,6,0"
                                        Click="Discover_Click"
                                        ToolTip="Scan the LAN for Hikvision cameras (SADP + TCP fallback) and add them"/>
                                <Button x:Name="LiveToggleButton" Content="ALPR toggle" Width="90"
                                        IsEnabled="False" Click="LiveToggleAlpr_Click"
                                        ToolTip="Toggle the selected camera's plate recognition while the pipeline is running (via REST API)"/>
                            </StackPanel>

                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Id"/>
                                    <TextBox x:Name="CamIdBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="Name"/>
                                    <TextBox x:Name="CamNameBox"/>
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="2">
                                <CheckBox x:Name="CamEnabledCheck" Content="Camera enabled"/>
                                <CheckBox x:Name="CamAlprCheck" Content="ALPR enabled"/>
                            </UniformGrid>
                            <Label Content="Source"/>
                            <ComboBox x:Name="CamSourceCombo">
                                <ComboBoxItem Content="simulation"/>
                                <ComboBoxItem Content="camera"/>
                            </ComboBox>
                            <Label Content="Video file (simulation)"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="..." Width="28" Margin="4,2,0,2" Click="BrowseVideo_Click"/>
                                <TextBox x:Name="CamVideoBox"/>
                            </DockPanel>
                            <Label Content="RTSP URL (camera)"/>
                            <TextBox x:Name="CamRtspBox"/>
                            <UniformGrid Columns="2">
                                <CheckBox x:Name="CamMotionCheck" Content="Motion gating"
                                          ToolTip="Run DNN only when the scene moves (biggest CPU saver)"/>
                                <StackPanel>
                                    <Label Content="Motion cooldown (s)"/>
                                    <TextBox x:Name="CamMotionCooldownBox"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Processing / ALPR">
                        <StackPanel>
                            <Label Content="Active model profile"/>
                            <ComboBox x:Name="ProfileCombo" SelectionChanged="ProfileCombo_SelectionChanged"/>
                            <Label Content="DNN backend (hardware acceleration)"/>
                            <ComboBox x:Name="BackendCombo">
                                <ComboBoxItem Content="cpu"/>
                                <ComboBoxItem Content="opencl"/>
                                <ComboBoxItem Content="opencl_fp16"/>
                                <ComboBoxItem Content="cuda"/>
                                <ComboBoxItem Content="cuda_fp16"/>
                            </ComboBox>
                            <CheckBox x:Name="VehicleCheck" Content="Vehicle-first detection (1 plate / vehicle)"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Vehicle confidence"/>
                                    <TextBox x:Name="VehicleConfBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="ALPR workers (0 = auto)"/>
                                    <TextBox x:Name="WorkerCountBox"
                                             ToolTip="Shared inference workers for ALL cameras. 0 = auto: scales with camera count and balances OpenCV threads against CPU cores to avoid oversubscription."/>
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Det. conf."/>
                                    <TextBox x:Name="DetConfBox"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="NMS"/>
                                    <TextBox x:Name="NmsBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="OCR conf."/>
                                    <TextBox x:Name="OcrConfBox"/>
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Dedup (s)"/>
                                    <TextBox x:Name="DedupBox"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="ALPR her N kare"/>
                                    <TextBox x:Name="EveryNBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="CPU threads (0=auto)"/>
                                    <TextBox x:Name="ThreadsBox"/>
                                </StackPanel>
                            </UniformGrid>
                            <Label Content="Max frame width, px (0 = original resolution)"/>
                            <TextBox x:Name="MaxFrameWidthBox"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Consolidation (one final result per plate)">
                        <StackPanel>
                            <CheckBox x:Name="ConsolEnabledCheck"
                                      Content="Consolidate multiple reads into one final"
                                      ToolTip="Groups jittery reads of the same plate and emits one voted result"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Finalize after (s)"/>
                                    <TextBox x:Name="ConsolFinalizeBox"
                                             ToolTip="Idle time after the plate leaves before emitting the final result"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="Min sightings"/>
                                    <TextBox x:Name="ConsolMinSightBox"
                                             ToolTip="Require this many reads before reporting a plate"/>
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Max edit distance"/>
                                    <TextBox x:Name="ConsolEditBox"
                                             ToolTip="Group reads within this many character differences"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="Max track (s)"/>
                                    <TextBox x:Name="ConsolMaxTrackBox"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Display / API">
                        <StackPanel>
                            <CheckBox x:Name="DisplayCheck" Content="Show camera wall (click tile = toggle ALPR)"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Wall width (px)"/>
                                    <TextBox x:Name="MaxWidthBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="API port"/>
                                    <TextBox x:Name="ApiPortBox"/>
                                </StackPanel>
                            </UniformGrid>
                            <CheckBox x:Name="ApiEnabledCheck" Content="REST API enabled"/>
                            <Label Content="API key (blank = no auth; first key from config)"/>
                            <TextBox x:Name="ApiKeyBox"
                                     ToolTip="Sent as X-API-Key on live status/snapshot/toggle calls. Must match one of api.api_keys."/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Detection snapshots (verification JPGs)">
                        <StackPanel>
                            <CheckBox x:Name="DetOutEnabledCheck"
                                      Content="Save an annotated JPG per reported plate"
                                      ToolTip="One timestamped, plate-labeled image per final result"/>
                            <Label Content="Output folder"/>
                            <TextBox x:Name="DetOutDirBox"/>
                            <CheckBox x:Name="DetOutTimestampCheck" Content="Burn timestamp banner"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Network (site server uplink)">
                        <StackPanel>
                            <CheckBox x:Name="NetEnabledCheck" Content="Send plate reports to site server (TCP)"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Server host"/>
                                    <TextBox x:Name="NetHostBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="Server port"/>
                                    <TextBox x:Name="NetPortBox"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Logging">
                        <StackPanel>
                            <Label Content="Level"/>
                            <ComboBox x:Name="LogLevelCombo">
                                <ComboBoxItem Content="debug"/>
                                <ComboBoxItem Content="info"/>
                                <ComboBoxItem Content="warn"/>
                                <ComboBoxItem Content="error"/>
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Right: live wall + detections + log -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2.4*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="1.2*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Live camera wall (click a tile to toggle its ALPR)">
                    <Border Background="#101010">
                        <UniformGrid x:Name="WallGrid"/>
                    </Border>
                </GroupBox>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>

                <GroupBox Grid.Row="2" Header="Detected plates">
                    <DataGrid x:Name="PlatesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="80"/>
                            <DataGridTextColumn Header="Camera" Binding="{Binding Camera}" Width="90"/>
                            <DataGridTextColumn Header="Plate" Binding="{Binding Text}" Width="130" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Det" Binding="{Binding DetConf}" Width="55"/>
                            <DataGridTextColumn Header="OCR" Binding="{Binding OcrConf}" Width="55"/>
                            <DataGridTextColumn Header="Box" Binding="{Binding Box}" Width="130"/>
                            <DataGridTextColumn Header="Frame" Binding="{Binding Seq}" Width="65"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <GridSplitter Grid.Row="3" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>

                <GroupBox Grid.Row="4" Header="Log">
                    <TextBox x:Name="LogBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"/>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
