<Window x:Class="AnprStudio.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ANPR Studio" Height="780" Width="1240" MinHeight="600" MinWidth="980"
        Closing="Window_Closing">
    <DockPanel>

        <!-- Top toolbar: paths + process control -->
        <Border DockPanel.Dock="Top" Background="#F0F0F0" Padding="8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition/>
                </Grid.RowDefinitions>

                <Label Grid.Row="0" Grid.Column="0" Content="anpr.exe:"/>
                <TextBox Grid.Row="0" Grid.Column="1" x:Name="ExePathBox"/>
                <Button Grid.Row="0" Grid.Column="2" Content="..." Width="28" Margin="4,2,0,2" Click="BrowseExe_Click"/>

                <Label Grid.Row="1" Grid.Column="0" Content="Config:"/>
                <TextBox Grid.Row="1" Grid.Column="1" x:Name="ConfigPathBox"/>
                <Button Grid.Row="1" Grid.Column="2" Content="..." Width="28" Margin="4,2,0,2" Click="BrowseConfig_Click"/>

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="3" Orientation="Horizontal" Margin="12,0,0,0">
                    <Button x:Name="ReloadButton" Content="Reload Config" Width="100" Margin="0,0,6,0" Click="ReloadConfig_Click"/>
                    <Button x:Name="SaveButton" Content="Save Config" Width="100" Margin="0,0,6,0" Click="SaveConfig_Click"/>
                </StackPanel>
                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="4" Orientation="Horizontal">
                    <Button x:Name="StartButton" Content="▶ Start" Width="90" FontWeight="Bold" Margin="0,0,6,0" Click="Start_Click"/>
                    <Button x:Name="StopButton" Content="■ Stop" Width="90" IsEnabled="False" Click="Stop_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Stopped"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="StatsText" Text=""/>
            </StatusBarItem>
        </StatusBar>

        <Grid Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="340"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: config editor -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ConfigPanel" IsEnabled="False">

                    <GroupBox Header="Capture">
                        <StackPanel>
                            <Label Content="Source"/>
                            <ComboBox x:Name="SourceCombo">
                                <ComboBoxItem Content="simulation"/>
                                <ComboBoxItem Content="camera"/>
                            </ComboBox>
                            <Label Content="Video file (simulation)"/>
                            <DockPanel>
                                <Button DockPanel.Dock="Right" Content="..." Width="28" Margin="4,2,0,2" Click="BrowseVideo_Click"/>
                                <TextBox x:Name="VideoPathBox"/>
                            </DockPanel>
                            <UniformGrid Columns="2">
                                <CheckBox x:Name="RealtimeCheck" Content="Realtime pacing"/>
                                <CheckBox x:Name="LoopCheck" Content="Loop video"/>
                            </UniformGrid>
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Target FPS"/>
                                    <TextBox x:Name="TargetFpsBox"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Frame skip"/>
                                    <TextBox x:Name="FrameSkipBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="Start (s)"/>
                                    <TextBox x:Name="StartTimeBox"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Processing / ALPR">
                        <StackPanel>
                            <Label Content="Active model profile"/>
                            <ComboBox x:Name="ProfileCombo" SelectionChanged="ProfileCombo_SelectionChanged"/>
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Det. conf."/>
                                    <TextBox x:Name="DetConfBox"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="NMS"/>
                                    <TextBox x:Name="NmsBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="OCR conf."/>
                                    <TextBox x:Name="OcrConfBox"/>
                                </StackPanel>
                            </UniformGrid>
                            <UniformGrid Columns="3">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Dedup (s)"/>
                                    <TextBox x:Name="DedupBox"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="ALPR her N kare"/>
                                    <TextBox x:Name="EveryNBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="CPU threads (0=auto)"/>
                                    <TextBox x:Name="ThreadsBox"/>
                                </StackPanel>
                            </UniformGrid>
                            <Label Content="Max frame width, px (0 = original resolution)"/>
                            <TextBox x:Name="MaxFrameWidthBox"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Display">
                        <StackPanel>
                            <CheckBox x:Name="DisplayCheck" Content="Show live annotated video"/>
                            <Label Content="Max window width (px)"/>
                            <TextBox x:Name="MaxWidthBox"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Network">
                        <StackPanel>
                            <CheckBox x:Name="NetEnabledCheck" Content="Enabled"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,0">
                                    <Label Content="Server host"/>
                                    <TextBox x:Name="HostBox"/>
                                </StackPanel>
                                <StackPanel>
                                    <Label Content="Port"/>
                                    <TextBox x:Name="PortBox"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Logging">
                        <StackPanel>
                            <Label Content="Level"/>
                            <ComboBox x:Name="LogLevelCombo">
                                <ComboBoxItem Content="debug"/>
                                <ComboBoxItem Content="info"/>
                                <ComboBoxItem Content="warn"/>
                                <ComboBoxItem Content="error"/>
                            </ComboBox>
                        </StackPanel>
                    </GroupBox>

                </StackPanel>
            </ScrollViewer>

            <GridSplitter Grid.Column="1" Width="8" HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- Right: detections + log -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="2*"/>
                    <RowDefinition Height="8"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <GroupBox Grid.Row="0" Header="Detected plates">
                    <DataGrid x:Name="PlatesGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              CanUserAddRows="False" HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Binding="{Binding Time}" Width="90"/>
                            <DataGridTextColumn Header="Plate" Binding="{Binding Text}" Width="140" FontWeight="Bold"/>
                            <DataGridTextColumn Header="Det" Binding="{Binding DetConf}" Width="60"/>
                            <DataGridTextColumn Header="OCR" Binding="{Binding OcrConf}" Width="60"/>
                            <DataGridTextColumn Header="Box" Binding="{Binding Box}" Width="140"/>
                            <DataGridTextColumn Header="Frame" Binding="{Binding Seq}" Width="70"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </GroupBox>

                <GridSplitter Grid.Row="1" Height="8" HorizontalAlignment="Stretch" Background="Transparent"/>

                <GroupBox Grid.Row="2" Header="Log">
                    <TextBox x:Name="LogBox" IsReadOnly="True" FontFamily="Consolas" FontSize="12"
                             VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto"
                             TextWrapping="NoWrap"/>
                </GroupBox>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
